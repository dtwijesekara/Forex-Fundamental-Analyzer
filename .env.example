# ============================================================
# FOREX FUNDAMENTAL ANALYZER — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# --- SUPABASE ---
# Get from: https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- TELEGRAM ALERTS (optional but recommended) ---
# Create bot: talk to @BotFather on Telegram → /newbot
# Get chat ID: message @userinfobot or check API response
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# --- API KEYS (optional, enhances data quality) ---
# Alpha Vantage: https://www.alphavantage.co/support/#api-key (free)
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here

# Finnhub: https://finnhub.io (free tier)
FINNHUB_API_KEY=your-finnhub-key-here

# --- APP SETTINGS ---
# Timezone for displaying events (e.g. Asia/Colombo, UTC, America/New_York)
USER_TIMEZONE=Asia/Colombo

# API secret for securing manual refresh endpoint
API_SECRET=change-this-to-a-random-strong-secret

# Vercel Cron secret (Vercel sets this automatically — copy from Vercel dashboard)
# https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs
CRON_SECRET=change-this-to-a-random-strong-secret

# How often to auto-refresh analysis (minutes)
REFRESH_INTERVAL_MINUTES=30

# --- WORKER SETTINGS (for separate worker process) ---
# Only needed if running workers/scheduler.ts separately
WORKER_CRON_CALENDAR=*/30 * * * *
WORKER_CRON_SCORING=0 * * * *
WORKER_CRON_ALERTS=*/15 * * * *
